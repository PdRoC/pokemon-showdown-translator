{
  "manifest_version": 3,
  "name": "Showdown Traductor Pro",
  "version": "1.0",
  "description": "Traducción dinámica para Pokémon Showdown",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://play.pokemonshowdown.com/*",
        "https://replay.pokemonshowdown.com/*"
      ],
      "js": ["jquery.min.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}