{
  "manifest_version": 3,
  "name": "Showd0wn Traductor Pro",
  "version": "1.0",
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["data/items.csv", "data/moves.csv", "data/abilities.csv"],
      "matches": ["https://play.pokemonshowdown.com/*", "https://replay.pokemonshowdown.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://play.pokemonshowdown.com/*",
        "https://replay.pokemonshowdown.com/*"
      ],
      "js": ["jquery.min.js", "content.js"]
    }
  ]
}